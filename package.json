{
  "name": "soulkiller",
  "version": "0.6.6",
  "description": "Extract your digital soul and create distributable AI avatars",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "soulkiller": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "bun src/index.tsx",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:visual": "bun vitest run --config vitest.visual.config.ts",
    "test:visual:update": "SOULKILLER_UPDATE_BASELINES=1 bun vitest run --config vitest.visual.config.ts",
    "test:integration": "bun vitest run --config vitest.integration.config.ts",
    "test:e2e": "bun tests/e2e/run-sequential.ts",
    "build:release": "bun scripts/build.ts",
    "dev:viewer": "bun src/export/state/viewer-server.ts"
  },
  "keywords": [
    "soulkiller",
    "ai",
    "avatar",
    "digital-soul",
    "cli",
    "repl"
  ],
  "author": "",
  "license": "GPL-3.0",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@mozilla/readability": "^0.6.0",
    "ai": "^6.0.142",
    "chalk": "^5.6.2",
    "exa-js": "^2.11.0",
    "fflate": "^0.8.2",
    "ink": "^6.8.0",
    "linkedom": "^0.18.12",
    "nanotar": "^0.3.0",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "turndown": "^7.2.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "ink-testing-library": "^4.0.0",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.2",
    "vite": "^6.3.0",
    "vitest": "^4.1.2"
  }
}
